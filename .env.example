# ─── 必填: eBird API 密钥 ────────────────────────
# 免费申请: https://ebird.org/api/keygen
EBIRD_API_KEY=

# ─── 区域设置 ────────────────────────────────────
# eBird 区域代码。CN-11=北京, CN-31=上海, CN-44=广东 ...
# 完整列表: https://support.ebird.org/en/support/solutions/articles/48000950516
BIRDING_REGION=CN-11

# 中国观鸟记录中心省份名（对应 BIRDING_REGION 的中文省份）
BIRDING_PROVINCE=北京

# ─── 可选: 观鸟记录中心共享令牌 ─────────────────
# 不填则使用公开数据
BIRDRECORD_SHARE_TOKEN=
